---
/**
 * Hero — Section hero flexible avec deux modes d'affichage.
 *
 * layout: 'centered' (défaut) — Texte centré, fond plein écran.
 * layout: 'split'             — Grille 2 colonnes desktop, texte en haut sur mobile.
 *
 * Fallback : si layout='split' sans foregroundImage → bascule sur 'centered'.
 * Le fond est délégué à BackgroundWrapper (@ui/BackgroundWrapper.astro).
 */

import BackgroundWrapper from '@ui/BackgroundWrapper.astro';

interface Props {
  title: string;
  subtitle: string;
  primaryCTA: { label: string; href: string };
  secondaryCTA?: { label: string; href: string };
  badge?: string;
  /** Mode d'affichage — 'centered' (défaut) ou 'split'. Fallback sur 'centered' si foregroundImage absent. */
  layout?: 'centered' | 'split';
  /** Image de premier plan — colonne droite en mode split */
  foregroundImage?: string;
  foregroundImageAlt?: string;
  backgroundType?: 'solid' | 'gradient' | 'image' | 'video';
  background?: 'default' | 'muted' | 'accent';
  gradient?: string;
  backgroundImage?: string;
  backgroundVideo?: string;
  backgroundVideoPoster?: string;
  overlay?: boolean;
  overlayOpacity?: number;
  textColor?: 'auto' | 'light' | 'dark';
  minHeight?: 'default' | 'screen' | 'large';
  align?: 'center' | 'left';
}

const {
  title,
  subtitle,
  primaryCTA,
  secondaryCTA,
  badge,
  layout = 'centered',
  foregroundImage,
  foregroundImageAlt = '',
  backgroundType = 'solid',
  background = 'default',
  gradient = 'from-primary/10 via-background to-background',
  backgroundImage,
  backgroundVideo,
  backgroundVideoPoster,
  overlay = false,
  overlayOpacity = 50,
  textColor = 'auto',
  minHeight = 'default',
  align = 'center',
} = Astro.props;

// Fallback : split sans image → centered
const effectiveLayout: 'centered' | 'split' =
  layout === 'split' && Boolean(foregroundImage) ? 'split' : 'centered';

const needsLightText =
  textColor === 'light' ||
  (textColor === 'auto' && (backgroundType === 'image' || backgroundType === 'video') && overlay);

const textClasses = needsLightText
  ? {
      heading: 'text-white',
      body:    'text-white/80',
      button:  'border-white/30 text-white hover:bg-white/10',
    }
  : {
      heading: 'text-text',
      body:    'text-text-muted',
      button:  'border-border text-text hover:bg-surface',
    };

const minHeightClass = {
  default: effectiveLayout === 'split' ? 'py-16 md:py-24' : 'py-section',
  large:   'py-24 md:py-32',
  screen:  'min-h-[80vh] flex items-center',
}[minHeight];

const badgeClass = needsLightText ? 'bg-white/20 text-white' : 'bg-primary/10 text-primary';

// Mode centered — alignement configurable
const alignClass       = align === 'left' ? 'text-left' : 'text-center mx-auto';
const buttonAlignClass = align === 'left' ? 'justify-start' : 'justify-center';
---

<BackgroundWrapper
  backgroundType={backgroundType}
  background={background}
  gradient={gradient}
  backgroundSrc={backgroundType === 'image' ? backgroundImage : undefined}
  backgroundVideo={backgroundType === 'video' ? backgroundVideo : undefined}
  backgroundVideoPoster={backgroundVideoPoster}
  overlay={overlay}
  overlayOpacity={overlayOpacity}
  class={[minHeightClass, minHeight === 'screen' ? 'flex items-center' : ''].filter(Boolean).join(' ')}
>

  {/* ══════════════════════════════════════════
      MODE CENTERED (défaut)
  ══════════════════════════════════════════ */}
  {effectiveLayout === 'centered' && (
    <div
      class:list={[
        'relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8',
        minHeight === 'screen' && 'w-full',
      ]}
    >
      <div class:list={['max-w-3xl', alignClass]}>
        {badge && (
          <span class:list={['inline-block mb-4 px-3 py-1 rounded-full text-sm font-medium', badgeClass]}>
            {badge}
          </span>
        )}
        <h1 class:list={['text-4xl sm:text-5xl lg:text-6xl font-bold leading-tight tracking-tight', textClasses.heading]}>
          {title}
        </h1>
        <p class:list={['mt-6 text-lg sm:text-xl leading-relaxed', textClasses.body]}>
          {subtitle}
        </p>
        <div class:list={['mt-10 flex flex-col sm:flex-row items-center gap-4', buttonAlignClass]}>
          <a
            href={primaryCTA.href}
            class="inline-flex items-center justify-center px-6 py-3 rounded-md bg-primary text-white font-medium hover:bg-primary-dark transition-colors w-full sm:w-auto"
          >
            {primaryCTA.label}
          </a>
          {secondaryCTA && (
            <a
              href={secondaryCTA.href}
              class:list={[
                'inline-flex items-center justify-center px-6 py-3 rounded-md border font-medium transition-colors w-full sm:w-auto',
                textClasses.button,
              ]}
            >
              {secondaryCTA.label}
            </a>
          )}
        </div>
      </div>
    </div>
  )}

  {/* ══════════════════════════════════════════
      MODE SPLIT (2 colonnes)
      Mobile : texte en haut (ordre DOM naturel), image en bas (h-56 / 224px)
      Desktop : grille lg:grid-cols-2, image max-h-[480px] object-cover
  ══════════════════════════════════════════ */}
  {effectiveLayout === 'split' && (
    <div
      class:list={[
        'relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8',
        minHeight === 'screen' && 'w-full',
      ]}
    >
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-16 items-center">

        {/* Colonne gauche : contenu (toujours en premier dans le DOM → toujours en haut sur mobile) */}
        <div class="text-left">
          {badge && (
            <span class:list={['inline-block mb-4 px-3 py-1 rounded-full text-sm font-medium', badgeClass]}>
              {badge}
            </span>
          )}
          <h1 class:list={['text-4xl sm:text-5xl lg:text-6xl font-bold leading-tight tracking-tight', textClasses.heading]}>
            {title}
          </h1>
          <p class:list={['mt-6 text-lg sm:text-xl leading-relaxed', textClasses.body]}>
            {subtitle}
          </p>
          <div class="mt-10 flex flex-col sm:flex-row items-start gap-4">
            <a
              href={primaryCTA.href}
              class="inline-flex items-center justify-center px-6 py-3 rounded-md bg-primary text-white font-medium hover:bg-primary-dark transition-colors w-full sm:w-auto"
            >
              {primaryCTA.label}
            </a>
            {secondaryCTA && (
              <a
                href={secondaryCTA.href}
                class:list={[
                  'inline-flex items-center justify-center px-6 py-3 rounded-md border font-medium transition-colors w-full sm:w-auto',
                  textClasses.button,
                ]}
              >
                {secondaryCTA.label}
              </a>
            )}
          </div>
        </div>

        {/* Colonne droite : image au premier plan */}
        <div class="flex justify-center lg:justify-end">
          <img
            src={foregroundImage}
            alt={foregroundImageAlt}
            class="w-full rounded-2xl shadow-2xl object-cover h-56 md:h-auto md:max-h-[480px]"
            loading="eager"
            fetchpriority="high"
          />
        </div>

      </div>
    </div>
  )}

</BackgroundWrapper>
