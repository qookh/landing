---
import { Icon } from 'astro-icon/components';

interface PricingPlan {
  name: string;
  price: number | null;
  priceLabel?: string;
  priceUnit?: string;
  priceBreakdown?: string[];
  description: string;
  features: string[];
  highlighted?: boolean;
  badge?: string;
  cta: { label: string; href: string };
}

interface Props {
  title?: string;
  subtitle?: string;
  trustBanner?: string;
  plans: PricingPlan[];
  footerLink?: { label: string; href: string };
  background?: 'default' | 'muted' | 'accent';
}

const {
  title,
  subtitle,
  trustBanner,
  plans,
  footerLink,
  background = 'default',
} = Astro.props;

const hasHeading = title || subtitle;

const bgClass = {
  default: 'bg-background',
  muted: 'bg-surface',
  accent: 'bg-primary/5',
}[background];
---

<section class:list={['py-section', bgClass]}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    {
      hasHeading && (
        <div class="text-center max-w-3xl mx-auto mb-8">
          {title && <h2 class="text-3xl sm:text-4xl font-bold text-text">{title}</h2>}
          {subtitle && <p class="mt-4 text-lg text-text-muted">{subtitle}</p>}
        </div>
      )
    }

    {
      trustBanner && (
        <div class="flex items-center justify-center gap-2 mb-12 text-sm text-text-muted">
          <Icon name="lucide:shield-check" class="w-4 h-4 text-primary shrink-0" />
          <span>{trustBanner}</span>
        </div>
      )
    }

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {
        plans.map((plan) => {
          const badgeText = plan.badge || null;
          const hasNumericPrice = plan.price !== null;

          return (
            <article
              class:list={[
                'relative flex flex-col p-8 rounded-lg border transition-all',
                plan.highlighted
                  ? 'bg-primary/5 border-primary shadow-lg scale-[1.02]'
                  : 'bg-surface border-border hover:border-primary/50 hover:shadow-md',
              ]}
            >
              {badgeText && (
                <div class="absolute -top-3 left-1/2 -translate-x-1/2">
                  <span class="inline-block px-3 py-1 text-xs font-semibold text-white bg-primary rounded-full whitespace-nowrap">
                    {badgeText}
                  </span>
                </div>
              )}

              <h3 class="text-xl font-semibold text-text">{plan.name}</h3>

              <div class="mt-6">
                {hasNumericPrice ? (
                  <>
                    <p class="text-sm text-text-muted">{plan.priceLabel}</p>
                    <p class="mt-1">
                      <span class="text-4xl font-bold text-text">{plan.price}</span>
                      <span class="ml-1 text-text-muted">{plan.priceUnit}</span>
                    </p>
                  </>
                ) : (
                  <>
                    <p class="text-4xl font-bold text-text">{plan.priceLabel}</p>
                    <p class="mt-1 text-sm text-text-muted">{plan.priceUnit}</p>
                  </>
                )}
                {plan.priceBreakdown && plan.priceBreakdown.length > 0 && (
                  <ul class="mt-3 space-y-1">
                    {plan.priceBreakdown.map((item) => (
                      <li class="text-sm text-text-muted">· {item}</li>
                    ))}
                  </ul>
                )}
              </div>

              <p class="mt-4 text-text-muted text-sm">{plan.description}</p>

              <hr
                class:list={['my-6', plan.highlighted ? 'border-primary/20' : 'border-border']}
              />

              <ul class="flex-1 space-y-4">
                {plan.features.map((feature) => (
                  <li class="flex items-start gap-3">
                    <Icon name="lucide:check" class="w-5 h-5 text-primary shrink-0 mt-0.5" />
                    <span class="text-text-muted text-sm">{feature}</span>
                  </li>
                ))}
              </ul>

              <div class="mt-8">
                <a
                  href={plan.cta.href}
                  class:list={[
                    'block w-full text-center px-6 py-3 rounded-md font-medium transition-colors',
                    plan.highlighted
                      ? 'bg-primary text-white hover:bg-primary-dark'
                      : 'bg-surface border border-border text-text hover:bg-background hover:border-primary/50',
                  ]}
                >
                  {plan.cta.label}
                </a>
              </div>
            </article>
          );
        })
      }
    </div>

    {
      footerLink && (
        <div class="text-center mt-10">
          <a
            href={footerLink.href}
            class="text-primary hover:text-primary-dark font-medium transition-colors"
          >
            {footerLink.label}
          </a>
        </div>
      )
    }
  </div>
</section>
