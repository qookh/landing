---
/**
 * PageHeader - En-tête de page réutilisable
 *
 * Même nommage que HeroConfig : backgroundType / backgroundSrc / background / gradient / overlay.
 *
 * @example Couleur thématique
 * ```astro
 * <PageHeader title="Nos services" backgroundType="solid" background="muted" />
 * ```
 *
 * @example Image de fond avec fallback couleur
 * ```astro
 * <PageHeader
 *   title="Contactez-nous"
 *   backgroundType="image"
 *   backgroundSrc="/images/header-contact.jpg"
 *   background="accent"
 *   overlay={true}
 * />
 * ```
 *
 * @example Dégradé personnalisé
 * ```astro
 * <PageHeader
 *   title="Nos réalisations"
 *   backgroundType="gradient"
 *   gradient="from-blue-900 to-indigo-700"
 * />
 * ```
 */

interface Props {
  /** Titre de la page (h1) */
  title: string;
  /** Sous-titre / description */
  subtitle?: string;
  /** Alignement du texte */
  align?: 'center' | 'left';
  /** Taille du titre */
  size?: 'default' | 'large';
  /** Largeur maximale du contenu */
  maxWidth?: 'sm' | 'md' | 'lg' | 'full';
  /** Discriminant de fond — même nommage que HeroConfig */
  backgroundType?: 'solid' | 'gradient' | 'image';
  /** Thème couleur — actif sur 'solid', aussi fallback CSS quand 'image' charge */
  background?: 'default' | 'muted' | 'accent';
  /** URL de l'image de fond (backgroundType: 'image') */
  backgroundSrc?: string;
  /** Classes Tailwind de dégradé (backgroundType: 'gradient') */
  gradient?: string;
  /** Overlay sombre pour lisibilité sur image — true par défaut */
  overlay?: boolean;
}

const {
  title,
  subtitle,
  align = 'center',
  size = 'default',
  maxWidth = 'lg',
  backgroundType = 'solid',
  background = 'default',
  backgroundSrc,
  gradient,
  overlay = true,
} = Astro.props;

const isImage    = backgroundType === 'image' && Boolean(backgroundSrc);
const isGradient = backgroundType === 'gradient';

// Couleur thématique — aussi fallback CSS pendant le chargement de l'image
const colorClass = { default: 'bg-background', muted: 'bg-surface', accent: 'bg-primary/5' }[background];

const bgClass = isImage
  ? `${colorClass} bg-cover bg-center bg-no-repeat`
  : isGradient
    ? `bg-gradient-to-r ${gradient ?? 'from-primary to-primary-dark'}`
    : colorClass;

const alignClass = align === 'left' ? 'text-left' : 'text-center';

const titleSizeClass =
  size === 'large' ? 'text-4xl sm:text-5xl lg:text-6xl' : 'text-4xl sm:text-5xl';

const maxWidthClass = {
  sm: 'max-w-xl',
  md: 'max-w-2xl',
  lg: 'max-w-3xl',
  full: 'max-w-none',
}[maxWidth];

const containerClass = align === 'center' ? `${maxWidthClass} mx-auto` : maxWidthClass;

const titleColor    = isImage || isGradient ? 'text-white'    : 'text-text';
const subtitleColor = isImage || isGradient ? 'text-white/80' : 'text-text-muted';
---

<section
  class:list={['py-section relative overflow-hidden', bgClass]}
  style={isImage ? { backgroundImage: `url('${backgroundSrc}')` } : undefined}
>
  {isImage && overlay && <div class="absolute inset-0 bg-black/50" aria-hidden="true" />}
  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class:list={[containerClass, alignClass]}>
      <h1 class:list={['font-bold leading-tight tracking-tight', titleSizeClass, titleColor]}>
        {title}
      </h1>
      {
        subtitle && (
          <p class:list={['mt-6 text-lg leading-relaxed', subtitleColor]}>{subtitle}</p>
        )
      }
      <slot />
    </div>
  </div>
</section>
