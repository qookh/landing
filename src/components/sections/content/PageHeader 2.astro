---
/**
 * PageHeader — En-tête de page réutilisable.
 *
 * Partage le même système de background que Hero via BackgroundWrapper (@ui/BackgroundWrapper.astro).
 * Deux modes d'affichage via `layout` :
 *   'centered' (défaut) — texte centré sur fond plein écran.
 *   'split'             — grille 2 colonnes : titre+contenu à gauche, image à droite.
 *
 * Fallback : layout='split' sans foregroundImage → bascule sur 'centered'.
 */

import BackgroundWrapper from '@ui/BackgroundWrapper.astro';

interface Props {
  title: string;
  subtitle?: string;
  align?: 'center' | 'left';
  size?: 'default' | 'large';
  maxWidth?: 'sm' | 'md' | 'lg' | 'full';
  /** Mode d'affichage. Fallback sur 'centered' si foregroundImage absent. */
  layout?: 'centered' | 'split';
  foregroundImage?: string;
  foregroundImageAlt?: string;
  backgroundType?: 'solid' | 'gradient' | 'image';
  background?: 'default' | 'muted' | 'accent';
  backgroundSrc?: string;
  gradient?: string;
  overlay?: boolean;
}

const {
  title,
  subtitle,
  align = 'center',
  size = 'default',
  maxWidth = 'lg',
  layout = 'centered',
  foregroundImage,
  foregroundImageAlt = '',
  backgroundType = 'solid',
  background = 'default',
  backgroundSrc,
  gradient,
  overlay = true,
} = Astro.props;

// Fallback : split sans image → centered
const effectiveLayout: 'centered' | 'split' =
  layout === 'split' && Boolean(foregroundImage) ? 'split' : 'centered';

const isImage    = backgroundType === 'image' && Boolean(backgroundSrc);
const isGradient = backgroundType === 'gradient';

const titleColor    = isImage || isGradient ? 'text-white'    : 'text-text';
const subtitleColor = isImage || isGradient ? 'text-white/80' : 'text-text-muted';

const titleSizeClass = size === 'large'
  ? 'text-4xl sm:text-5xl lg:text-6xl'
  : 'text-4xl sm:text-5xl';

// Mode centered — maxWidth + alignement
const maxWidthClass   = { sm: 'max-w-xl', md: 'max-w-2xl', lg: 'max-w-3xl', full: 'max-w-none' }[maxWidth];
const textAlignClass  = align === 'left' ? 'text-left' : 'text-center';
const centeredWrapper = align === 'center' ? `${maxWidthClass} mx-auto` : maxWidthClass;
---

<BackgroundWrapper
  backgroundType={backgroundType}
  background={background}
  backgroundSrc={backgroundSrc}
  gradient={gradient}
  overlay={overlay}
  class="py-section"
>
  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    {/* ── Grille unifiée : 1 colonne (centered) ou 2 colonnes lg (split) ── */}
    <div
      class:list={[
        'grid gap-8 lg:gap-16 items-center',
        effectiveLayout === 'split' ? 'grid-cols-1 lg:grid-cols-2' : 'grid-cols-1',
      ]}
    >
      {/* Colonne contenu — wrapper différent selon le mode */}
      <div
        class:list={[
          effectiveLayout === 'centered' ? [centeredWrapper, textAlignClass] : 'text-left',
        ]}
      >
        <h1 class:list={['font-bold leading-tight tracking-tight', titleSizeClass, titleColor]}>
          {title}
        </h1>
        {subtitle && (
          <p class:list={['mt-4 text-lg leading-relaxed', subtitleColor]}>{subtitle}</p>
        )}
        <slot />
      </div>

      {/* Colonne image — visible uniquement en mode split */}
      {effectiveLayout === 'split' && (
        <div class="flex justify-center lg:justify-end">
          <img
            src={foregroundImage}
            alt={foregroundImageAlt}
            class="w-full rounded-xl shadow-lg object-cover h-40 md:h-auto md:max-h-[340px]"
            loading="lazy"
          />
        </div>
      )}

    </div>
  </div>
</BackgroundWrapper>
