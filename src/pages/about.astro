---
import aboutJson from '@/data/pages/about.json';
import type { AboutPageConfig } from '@/types/pages';

import MarketingLayout from '@/layouts/MarketingLayout.astro';
import PageHeader from '@sections/content/PageHeader.astro';
import StatsSection from '@sections/social-proof/StatsSection.astro';
import VideoEmbed from '@sections/content/VideoEmbed.astro';
import ValuesSection from '@sections/team/ValuesSection.astro';
import TeamSection from '@sections/team/TeamSection.astro';
import ContentSection from '@sections/content/ContentSection.astro';
import CTA from '@sections/marketing/CTA.astro';

const cfg = aboutJson as AboutPageConfig;

const pageTitle = cfg.seo?.title ?? cfg.header.title;
const pageDescription = cfg.seo?.description ?? '';
---

<MarketingLayout
  title={pageTitle}
  description={pageDescription}
  image={cfg.seo?.image}
  tags={cfg.seo?.keywords}
>
  <PageHeader
    layout={cfg.header.layout}
    title={cfg.header.title}
    subtitle={cfg.header.subtitle}
    align={cfg.header.align}
    maxWidth={cfg.header.maxWidth}
    size={cfg.header.size}
    foregroundImage={cfg.header.foregroundImage}
    foregroundImageAlt={cfg.header.foregroundImageAlt}
    backgroundType={cfg.header.backgroundType}
    background={cfg.header.background}
    backgroundSrc={cfg.header.backgroundSrc}
    overlay={cfg.header.overlay}
  >
    {
      cfg.header.paragraphs?.map((p) => (
        <p class:list={['mt-4 text-lg leading-relaxed', cfg.header.backgroundType === 'image' ? 'text-white/80' : 'text-text-muted']}>{p}</p>
      ))
    }
  </PageHeader>

  {cfg.stats && <StatsSection {...cfg.stats} background="muted" />}

  {cfg.video && <VideoEmbed {...cfg.video} background="default" />}

  {
    cfg.values && (
      <ValuesSection
        title={cfg.values.title}
        subtitle={cfg.values.subtitle}
        items={cfg.values.items}
        variant={cfg.values.variant ?? 'card'}
        columns={cfg.values.columns ?? 2}
        background="default"
      />
    )
  }

  {
    cfg.team && (
      <TeamSection
        title={cfg.team.title}
        subtitle={cfg.team.subtitle}
        members={cfg.team.members}
        columns={cfg.team.columns ?? 4}
        background="muted"
      />
    )
  }

  {
    cfg.content && (
      <ContentSection
        title={cfg.content.title}
        subtitle={cfg.content.subtitle}
        content={cfg.content.paragraphs}
        align={cfg.content.align ?? 'left'}
        maxWidth={cfg.content.maxWidth ?? 'lg'}
        background="default"
      />
    )
  }

  {
    cfg.cta && (
      <CTA
        {...cfg.cta}
        description={cfg.cta.description ?? ''}
        action={cfg.cta.action ?? { label: 'Contact', href: '/contact' }}
        background="muted"
      />
    )
  }
</MarketingLayout>
