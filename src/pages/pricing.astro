---
import pricingJson from '@/data/pages/pricing.json';
import type { PricingPageConfig } from '@/types/pages';

import MarketingLayout from '@/layouts/MarketingLayout.astro';
import PricingTable from '@sections/pricing/PricingTable.astro';
import ComparisonTable from '@sections/pricing/ComparisonTable.astro';
import TrustBadges from '@sections/pricing/TrustBadges.astro';
import FAQSection from '@sections/content/FAQSection.astro';
import CTA from '@sections/marketing/CTA.astro';

const cfg = pricingJson as PricingPageConfig;

const pageTitle = cfg.seo?.title ?? 'Tarifs';
const pageDescription = cfg.seo?.description ?? '';
---

<MarketingLayout
  title={pageTitle}
  description={pageDescription}
  image={cfg.seo?.image}
  tags={cfg.seo?.keywords}
>
  <PricingTable
    plans={cfg.plans}
    annualDiscount={cfg.annualDiscount}
    defaultPeriod={cfg.defaultPeriod}
  />

  {cfg.guarantee && <TrustBadges guarantee={cfg.guarantee} badges={cfg.badges} />}

  {
    cfg.comparison && (
      <ComparisonTable
        title={cfg.comparison.title}
        subtitle={cfg.comparison.subtitle}
        plans={cfg.comparison.plans}
        categories={cfg.comparison.categories}
        highlightedPlan={cfg.comparison.highlightedPlan}
        background="default"
      />
    )
  }

  {
    cfg.faqs && cfg.faqs.length > 0 && (
      <FAQSection
        title={cfg.faqTitle}
        faqs={cfg.faqs}
        variant={cfg.faqVariant ?? 'simple'}
        background="muted"
      />
    )
  }

  {
    cfg.cta && (
      <CTA
        {...cfg.cta}
        description={cfg.cta.description ?? ''}
        action={cfg.cta.action ?? { label: 'Contact', href: '/contact' }}
        background="muted"
      />
    )
  }
</MarketingLayout>
