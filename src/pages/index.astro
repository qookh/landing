---
/**
 * Landing page pilotée par src/data/config.json.
 *
 * Pour changer le contenu : modifier uniquement config.json.
 * Pour changer le design  : modifier les composants dans src/components.
 *
 * Optimisation Cloudflare :
 * - La page est pré-rendue (SSG) et mise en cache à la périphérie (edge).
 * - Les assets (/images/, /logos/) utilisent des chemins absolus pour que
 *   Cloudflare Pages les serve depuis le CDN sans aucune configuration.
 * - Le hero utilise loading="eager" + fetchpriority="high" (cf. Hero.astro).
 * - Toutes les images hors-écran utilisent loading="lazy" (comportement par défaut).
 */

import configJson from '@/data/config.json';
import type { SiteConfig } from '@/types/config';

import MarketingLayout from '@/layouts/MarketingLayout.astro';
import Hero from '@sections/marketing/Hero.astro';
import LogoCloud from '@sections/marketing/LogoCloud.astro';
import FeaturesSection from '@sections/marketing/FeaturesSection.astro';
import HowItWorks from '@sections/marketing/HowItWorks.astro';
import FeatureHighlight from '@sections/marketing/FeatureHighlight.astro';
import BentoGrid from '@sections/marketing/BentoGrid.astro';
import IntegrationsGrid from '@sections/marketing/IntegrationsGrid.astro';
import CTA from '@sections/marketing/CTA.astro';
import Newsletter from '@sections/marketing/Newsletter.astro';
import StatsSection from '@sections/social-proof/StatsSection.astro';
import TestimonialsSection from '@sections/social-proof/TestimonialsSection.astro';
import PricingTable from '@sections/pricing/PricingTable.astro';
import ComparisonTable from '@sections/pricing/ComparisonTable.astro';
import FAQSection from '@sections/content/FAQSection.astro';

const cfg = configJson as SiteConfig;

// ── SEO ──────────────────────────────────────────────────────────────────────
const pageTitle =
  cfg.global?.seo?.title ??
  (cfg.global ? `${cfg.global.name} — ${cfg.global.description}` : 'Landing');
const pageDescription = cfg.global?.seo?.description ?? cfg.global?.description ?? '';
const pageImage = cfg.global?.seo?.image;
const pageTags = cfg.global?.seo?.keywords;

// ── Props normalisés par section ─────────────────────────────────────────────
// Les props sont pré-résolus ici pour permettre l'usage du spread dans le template.
// Les fallbacks garantissent que les props requis par les composants sont toujours présents.

const heroProps = cfg.hero
  ? {
      ...cfg.hero,
      subtitle: cfg.hero.subtitle ?? '',
      primaryCTA: cfg.hero.primaryCTA ?? { label: 'Contact', href: '/contact' },
      // backgroundSrc est splittée en backgroundImage / backgroundVideo selon le type
      backgroundImage: cfg.hero.backgroundType === 'image' ? cfg.hero.backgroundSrc : undefined,
      backgroundVideo: cfg.hero.backgroundType === 'video' ? cfg.hero.backgroundSrc : undefined,
    }
  : null;

const featuresProps = cfg.features
  ? {
      ...cfg.features,
      // FeaturesSection exige icon: string (non optionnel) — fallback sur l'icône générique
      features: cfg.features.features.map((f) => ({ ...f, icon: f.icon ?? 'lucide:check' })),
    }
  : null;

// TestimonialsSection exige role: string et company: string (non optionnels)
const testimonialsProps = cfg.testimonials
  ? {
      ...cfg.testimonials,
      testimonials: cfg.testimonials.testimonials.map((t) => ({
        ...t,
        role: t.role ?? '',
        company: t.company ?? '',
      })),
    }
  : null;

const integrationsProps = cfg.integrations
  ? {
      ...cfg.integrations,
      // columns est 3|4|5|6 dans le composant, number dans la config
      columns: (cfg.integrations.columns ?? 3) as 3 | 4 | 5 | 6,
    }
  : null;

const ctaProps = cfg.cta
  ? {
      ...cfg.cta,
      description: cfg.cta.description ?? '',
      action: cfg.cta.action ?? { label: 'Nous contacter', href: '/contact' },
    }
  : null;

// ── Ordre des sections ────────────────────────────────────────────────────────
// Défini dans config.json via "sectionOrder": ["hero", "features", ...].
// Si absent, l'ordre éditorial par défaut ci-dessous est utilisé.
const DEFAULT_ORDER = [
  'hero',
  'logoCloud',
  'features',
  'howItWorks',
  'featureHighlight',
  'bentoGrid',
  'integrations',
  'stats',
  'testimonials',
  'pricing',
  'comparisonTable',
  'faq',
  'cta',
  'newsletter',
] as const;

type SectionKey = (typeof DEFAULT_ORDER)[number];
const sectionOrder: SectionKey[] = (cfg.sectionOrder as SectionKey[] | undefined) ?? [
  ...DEFAULT_ORDER,
];

// Alternance automatique des fonds : pair = default, impair = muted
const bg = (idx: number): 'default' | 'muted' => (idx % 2 === 0 ? 'default' : 'muted');
---

<MarketingLayout
  title={pageTitle}
  description={pageDescription}
  image={pageImage}
  tags={pageTags}
>
  {
    sectionOrder.map((key, idx) => {
      if (key === 'hero' && heroProps) {
        return <Hero {...heroProps} />;
      }
      if (key === 'logoCloud' && cfg.logoCloud) {
        return <LogoCloud {...cfg.logoCloud} />;
      }
      if (key === 'features' && featuresProps) {
        return <FeaturesSection {...featuresProps} background={bg(idx)} />;
      }
      if (key === 'howItWorks' && cfg.howItWorks) {
        return <HowItWorks {...cfg.howItWorks} background={bg(idx)} />;
      }
      if (key === 'featureHighlight' && cfg.featureHighlight) {
        return <FeatureHighlight {...cfg.featureHighlight} />;
      }
      if (key === 'bentoGrid' && cfg.bentoGrid) {
        return <BentoGrid {...cfg.bentoGrid} background={bg(idx)} />;
      }
      if (key === 'integrations' && integrationsProps) {
        return <IntegrationsGrid {...integrationsProps} background={bg(idx)} />;
      }
      if (key === 'stats' && cfg.stats) {
        return <StatsSection {...cfg.stats} background={bg(idx)} />;
      }
      if (key === 'testimonials' && testimonialsProps && testimonialsProps.testimonials.length > 0) {
        return <TestimonialsSection {...testimonialsProps} background={bg(idx)} />;
      }
      if (key === 'pricing' && cfg.pricing) {
        return <PricingTable {...cfg.pricing} background={bg(idx)} />;
      }
      if (key === 'comparisonTable' && cfg.comparisonTable) {
        return <ComparisonTable {...cfg.comparisonTable} background={bg(idx)} />;
      }
      if (key === 'faq' && cfg.faq) {
        return <FAQSection {...cfg.faq} background={bg(idx)} />;
      }
      if (key === 'cta' && ctaProps) {
        return <CTA {...ctaProps} />;
      }
      if (key === 'newsletter' && cfg.newsletter) {
        return <Newsletter {...cfg.newsletter} />;
      }
      return null;
    })
  }
</MarketingLayout>
