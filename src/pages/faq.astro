---
import faqJson from '@/data/pages/faq.json';
import type { FAQPageConfig } from '@/types/pages';

import MarketingLayout from '@/layouts/MarketingLayout.astro';
import PageHeader from '@sections/content/PageHeader.astro';
import FAQSection from '@sections/content/FAQSection.astro';
import CTA from '@sections/marketing/CTA.astro';

const cfg = faqJson as FAQPageConfig;

const pageTitle = cfg.seo?.title ?? cfg.header.title;
const pageDescription = cfg.seo?.description ?? '';
---

<MarketingLayout
  title={pageTitle}
  description={pageDescription}
  image={cfg.seo?.image}
  tags={cfg.seo?.keywords}
>
  <PageHeader {...cfg.header} />

  <FAQSection
    categories={cfg.categories}
    faqs={cfg.faqs}
    variant={cfg.variant ?? 'accordion'}
    background="default"
  />

  {
    cfg.cta && (
      <CTA
        {...cfg.cta}
        description={cfg.cta.description ?? ''}
        action={cfg.cta.action ?? { label: 'Contact', href: '/contact' }}
        background="muted"
      />
    )
  }
</MarketingLayout>
