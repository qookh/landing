---
import errorsJson from '@/data/pages/errors.json';
import type { ErrorsPageConfig } from '@/types/pages';

import ErrorLayout from '@/layouts/ErrorLayout.astro';
import ErrorPage from '@components/error/ErrorPage.astro';

const cfg = (errorsJson as ErrorsPageConfig)['404'];
---

<ErrorLayout title={cfg.layoutTitle} description={cfg.layoutDescription}>
  <ErrorPage
    code={cfg.code}
    title={cfg.title}
    message={cfg.message}
    showHomeButton={cfg.showHomeButton}
    showContactButton={cfg.showContactButton}
  />
</ErrorLayout>
