---
import customersJson from '@/data/pages/customers.json';
import type { CustomersPageConfig } from '@/types/pages';

import MarketingLayout from '@/layouts/MarketingLayout.astro';
import PageHeader from '@sections/content/PageHeader.astro';
import CaseStudyCard from '@sections/social-proof/CaseStudyCard.astro';
import LogoCloud from '@sections/marketing/LogoCloud.astro';
import StatsSection from '@sections/social-proof/StatsSection.astro';
import CTA from '@sections/marketing/CTA.astro';

const cfg = customersJson as CustomersPageConfig;

const pageTitle = cfg.seo?.title ?? cfg.header.title;
const pageDescription = cfg.seo?.description ?? '';
---

<MarketingLayout
  title={pageTitle}
  description={pageDescription}
  image={cfg.seo?.image}
  tags={cfg.seo?.keywords}
>
  <PageHeader {...cfg.header} />

  {cfg.stats && <StatsSection {...cfg.stats} background="muted" />}

  {
    cfg.featuredCases && (
      <CaseStudyCard
        title={cfg.featuredCases.title}
        subtitle={cfg.featuredCases.subtitle}
        cases={cfg.featuredCases.cases}
        variant="featured"
        background="default"
      />
    )
  }

  {
    cfg.gridCases && (
      <CaseStudyCard
        title={cfg.gridCases.title}
        subtitle={cfg.gridCases.subtitle}
        cases={cfg.gridCases.cases}
        variant="grid"
        background="muted"
      />
    )
  }

  {cfg.logoCloud && <LogoCloud {...cfg.logoCloud} background="default" />}

  {
    cfg.cta && (
      <CTA
        {...cfg.cta}
        description={cfg.cta.description ?? ''}
        action={cfg.cta.action ?? { label: 'Contact', href: '/contact' }}
        background="muted"
      />
    )
  }
</MarketingLayout>
