---
import termsJson from '@/data/pages/terms.json';
import type { LegalPageConfig } from '@/types/pages';

import MarketingLayout from '@/layouts/MarketingLayout.astro';

const cfg = termsJson as LegalPageConfig;
---

<MarketingLayout
  title={cfg.seo?.title ?? cfg.title}
  description={cfg.seo?.description ?? ''}
  image={cfg.seo?.image}
  tags={cfg.seo?.keywords}
>
  <section class="py-section">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <header class="mb-12">
        <h1 class="text-4xl font-bold text-text">{cfg.title}</h1>
        <p class="mt-4 text-text-muted">Dernière mise à jour : {cfg.lastUpdated}</p>
      </header>

      <div class="prose prose-lg max-w-none dark:prose-invert">
        {cfg.intro && <p>{cfg.intro}</p>}

        {
          cfg.sections.map((s) => (
            <>
              {s.heading && <h2>{s.heading}</h2>}
              {s.subheading && <h3>{s.subheading}</h3>}
              {s.content && <p>{s.content}</p>}
              {s.items && (
                <ul>
                  {s.items.map((item) => (
                    <li>{item}</li>
                  ))}
                </ul>
              )}
            </>
          ))
        }

        <h2>Nous contacter</h2>
        <ul>
          <li>Email : {cfg.contactEmail}</li>
          <li>Adresse : {cfg.address}</li>
        </ul>
      </div>
    </div>
  </section>
</MarketingLayout>
