---
import featuresJson from '@/data/pages/features.json';
import type { FeaturesPageConfig } from '@/types/pages';

import MarketingLayout from '@/layouts/MarketingLayout.astro';
import PageHeader from '@sections/content/PageHeader.astro';
import FeatureHighlight from '@sections/marketing/FeatureHighlight.astro';
import ValuesSection from '@sections/team/ValuesSection.astro';
import BentoGrid from '@sections/marketing/BentoGrid.astro';
import CTA from '@sections/marketing/CTA.astro';

const cfg = featuresJson as FeaturesPageConfig;

const pageTitle = cfg.seo?.title ?? cfg.header.title;
const pageDescription = cfg.seo?.description ?? '';
---

<MarketingLayout
  title={pageTitle}
  description={pageDescription}
  image={cfg.seo?.image}
  tags={cfg.seo?.keywords}
>
  <PageHeader {...cfg.header} />

  {
    cfg.highlight && (
      <FeatureHighlight
        title={cfg.highlight.title}
        subtitle={cfg.highlight.subtitle}
        features={cfg.highlight.features}
        background="muted"
      />
    )
  }

  {
    cfg.categories?.map((category, idx) => (
      <ValuesSection
        title={category.title}
        subtitle={category.subtitle}
        items={category.items}
        variant={category.variant ?? 'with-icon'}
        columns={category.columns ?? 2}
        background={idx % 2 === 0 ? 'default' : 'muted'}
      />
    ))
  }

  {
    cfg.bentoGrid && (
      <BentoGrid
        title={cfg.bentoGrid.title}
        subtitle={cfg.bentoGrid.subtitle}
        items={cfg.bentoGrid.items}
        background="muted"
      />
    )
  }

  {
    cfg.cta && (
      <CTA
        {...cfg.cta}
        description={cfg.cta.description ?? ''}
        action={cfg.cta.action ?? { label: 'Contact', href: '/contact' }}
        background="muted"
      />
    )
  }
</MarketingLayout>
